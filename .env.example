# Boot-level paths + bind. These are read every start, not stored in DB.
DATA_DIR=./data
PORT=7000
BIND_HOST=127.0.0.1

# Optional first-run seed of shared config. Written to SQLite on the very
# first start when the `config` table is empty; ignored thereafter — edit
# values in the UI (`/config/chr`). Per-device settings (host, port, JWT
# token) are NOT seedable from env — register each device through the UI.
# CHR_API_URL=https://api.your-c-hr.example.com/api/v1
# POLL_INTERVAL_MIN=5
