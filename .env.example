# Boot-level paths + bind. Read every start, not stored in DB.
DATA_DIR=./data
PORT=7000
BIND_HOST=127.0.0.1

# Optional first-run seed of shared config. Written to SQLite on the very
# first start when the `config` table is empty; ignored thereafter — edit
# values in the UI (`/config/api`). Per-device settings (host, port, JWT
# token) are NOT seedable from env — register each device through the UI.
# PUSH_URL=https://api.example.com/v1/attendance/push
# PING_URL=https://api.example.com/v1/attendance/ping
# POLL_INTERVAL_MIN=5
