{
  "name": "@hanoilab/zk-bridge",
  "version": "0.1.2",
  "private": false,
  "description": "Pull-side bridge for ZKTeco attendance devices — polls over LAN and pushes events to any HTTP backend",
  "keywords": [
    "zkteco",
    "attendance",
    "bridge",
    "biometric",
    "fingerprint",
    "lan",
    "iclock",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyendinhphongdx/c-hr.git",
    "directory": "services/zk-bridge"
  },
  "main": "dist/index.js",
  "bin": {
    "zk-bridge": "dist/cli/zk-bridge.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "poll:once": "ts-node src/index.ts --once",
    "reset-user": "node dist/cli/reset-user.js",
    "recent-events": "node dist/cli/recent-events.js",
    "cli": "node dist/cli/zk-bridge.js",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "node-zklib": "^1.3.0",
    "sequelize": "^6.37.5",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
